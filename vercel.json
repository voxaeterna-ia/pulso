/* ============================================
   PULSO · UTILIDADES DE UI
   Formato de números, fechas, render
   ============================================ */

const PulsoUI = {

  // ============= FORMATO =============
  fmt(num, opts = {}) {
    if (num == null || isNaN(num)) return '—';
    const decimals = opts.decimals != null ? opts.decimals : 0;
    return new Intl.NumberFormat('es-AR', {
      minimumFractionDigits: decimals,
      maximumFractionDigits: decimals
    }).format(num);
  },

  fmtMoney(num, opts = {}) {
    if (num == null || isNaN(num)) return '$—';
    return '$' + this.fmt(num, opts);
  },

  fmtPct(num, withSign = true) {
    if (num == null || isNaN(num)) return '—';
    const sign = num > 0 ? '+' : '';
    const arrow = num > 0 ? '▲' : (num < 0 ? '▼' : '◆');
    const abs = Math.abs(num).toFixed(num < 1 && num > -1 ? 2 : 1);
    return withSign ? `${arrow} ${sign}${abs}%` : `${abs}%`;
  },

  // ============= TIEMPO DE VIDA =============
  // Convertir monto a horas + minutos a partir del valor hora del usuario
  // Ejemplo: $3.500 con valor hora $5.313 → "0 h 40 min"
  // Ejemplo: $223.000 con valor hora $5.313 → "42 h 0 min"
  montoATiempo(monto, valorHora) {
    if (!valorHora || valorHora <= 0 || monto == null) return null;
    const horasDecimal = Math.abs(monto) / valorHora;
    const horas = Math.floor(horasDecimal);
    const minutos = Math.round((horasDecimal - horas) * 60);
    // Si los minutos llegaron a 60 por redondeo, lo paso a la hora siguiente
    if (minutos === 60) return { horas: horas + 1, minutos: 0, totalHoras: horasDecimal };
    return { horas, minutos, totalHoras: horasDecimal };
  },

  fmtTiempo(monto, valorHora, opts = {}) {
    const t = this.montoATiempo(monto, valorHora);
    if (!t) return '—';
    // Modo corto: "42 h 0 min" o "0 h 40 min"
    if (opts.short) return `${t.horas} h ${t.minutos} min`;
    // Modo con días laborales si es >= 1 día (8 hs)
    if (t.totalHoras >= 8 && opts.withDias) {
      const dias = (t.totalHoras / 8).toFixed(1);
      return `${t.horas} h ${t.minutos} min · ${dias} días`;
    }
    return `${t.horas} h ${t.minutos} min`;
  },

  // Tiempo breve para celdas chicas: omite el min si es 0
  fmtTiempoCorto(monto, valorHora) {
    const t = this.montoATiempo(monto, valorHora);
    if (!t) return '—';
    if (t.horas === 0) return `${t.minutos} min`;
    if (t.minutos === 0) return `${t.horas} h`;
    return `${t.horas} h ${t.minutos} min`;
  },

  fmtMonto(num) {
    if (num >= 1000000) return '$' + (num / 1000000).toFixed(1) + 'M';
    if (num >= 1000) return '$' + Math.round(num / 1000) + 'K';
    return '$' + num;
  },

  fmtUSD(num, decimals = 2) {
    if (num == null || isNaN(num)) return '—';
    if (num >= 1000) return 'US$ ' + this.fmt(num, { decimals: 0 });
    return 'US$ ' + this.fmt(num, { decimals });
  },

  fmtFecha(d) {
    if (!d) return '';
    const fecha = typeof d === 'string' ? new Date(d + (d.includes('T') ? '' : 'T12:00:00')) : new Date(d);
    const today = new Date();
    const yest = new Date();
    yest.setDate(yest.getDate() - 1);
    const months = ['ene', 'feb', 'mar', 'abr', 'may', 'jun', 'jul', 'ago', 'sep', 'oct', 'nov', 'dic'];

    if (fecha.toDateString() === today.toDateString()) {
      return 'hoy · ' + fecha.getDate() + ' ' + months[fecha.getMonth()];
    }
    if (fecha.toDateString() === yest.toDateString()) {
      return 'ayer · ' + fecha.getDate() + ' ' + months[fecha.getMonth()];
    }
    return fecha.getDate() + ' ' + months[fecha.getMonth()];
  },

  fmtFechaCompleta() {
    const d = new Date();
    const dias = ['domingo', 'lunes', 'martes', 'miércoles', 'jueves', 'viernes', 'sábado'];
    const months = ['ene', 'feb', 'mar', 'abr', 'may', 'jun', 'jul', 'ago', 'sep', 'oct', 'nov', 'dic'];
    return `${dias[d.getDay()]} ${d.getDate()} ${months[d.getMonth()]}`;
  },

  todayISO() {
    return new Date().toISOString().split('T')[0];
  },

  // ============= TOAST =============
  toast(msg, duration = 2200) {
    const t = document.getElementById('toast');
    if (!t) return;
    t.textContent = msg;
    t.classList.add('show');
    clearTimeout(this._toastTimer);
    this._toastTimer = setTimeout(() => t.classList.remove('show'), duration);
  },

  // ============= MODAL =============
  showModal(html) {
    const modal = document.getElementById('modal');
    document.getElementById('modalContent').innerHTML = html;
    modal.classList.add('show');
  },

  closeModal() {
    document.getElementById('modal').classList.remove('show');
  },

  // ============= CHIP DE PILL UP/DOWN =============
  pillFor(chgPct) {
    if (chgPct == null || isNaN(chgPct)) return '<span class="pill">—</span>';
    const cls = chgPct >= 0 ? 'pill-up' : 'pill-down';
    return `<span class="pill ${cls}">${this.fmtPct(chgPct)}</span>`;
  },

  // ============= PULSO DEL DÍA (cálculo emocional) =============
  // Toma indicadores y devuelve un score 0-100
  calcPulso({ blueChg = 0, riesgo = 700, inflacion = 2.5 }) {
    // Lógica simple: blue baja + riesgo bajo + inflación baja = más alto
    let score = 50;

    // Inflación: cada 1% mensual resta 4 puntos
    score -= Math.max(0, (inflacion - 1) * 4);

    // Riesgo país: cada 100 puntos sobre 500 resta 3 puntos
    score -= Math.max(0, (riesgo - 500) / 100 * 3);

    // Blue subiendo resta puntos (volatilidad), bajando suma
    score -= blueChg * 2;

    score = Math.max(5, Math.min(95, Math.round(score)));

    let emoji, estado;
    if (score < 30) { emoji = '😱'; estado = 'Crisis aguda'; }
    else if (score < 45) { emoji = '😬'; estado = 'Tensión moderada'; }
    else if (score < 60) { emoji = '😐'; estado = 'Estabilidad relativa'; }
    else if (score < 80) { emoji = '🙂'; estado = 'Aire fresco'; }
    else { emoji = '🤑'; estado = 'Bonanza'; }

    return { score, emoji, estado };
  }
};

window.PulsoUI = PulsoUI;
