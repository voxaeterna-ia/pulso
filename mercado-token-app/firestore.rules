rules_version = '2';
service cloud.firestore.firebase.app {
  match /databases/{database}/documents {
    // Solo se persisten kycStatus y kycValidatedAt (resultado de la
    // verificación). Las imágenes del documento/selfie y los datos
    // extraídos de ellas nunca se escriben en Firestore.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /assets/{assetId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /investments/{investmentId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }
  }
}
